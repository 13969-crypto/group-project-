overall_record = {
    "user_wins": 0,
    "computer_wins": 0,
    "ties": 0
}

history = []


def play_rps():
    print("\nStarting Rock Paper Scissors Shoot...")
    return {
        "game": "Rock Paper Scissors Shoot",
        "user_score": 1,
        "computer_score": 0,
        "winner": "User"
    }

def play_connect4():
    print("\nStarting Connect 4...")
    return {
        "game": "Connect 4",
        "user_score": 0,
        "computer_score": 1,
        "winner": "Computer"
    }

def play_word_guesser():
    print("\nStarting Word Guesser...")
    return {
        "game": "Word Guesser",
        "user_score": 1,
        "computer_score": 1,
        "winner": "Tie"
    }

def update_record(result):
    if result["winner"] == "User":
        overall_record["user_wins"] += 1
    elif result["winner"] == "Computer":
        overall_record["computer_wins"] += 1
    else:
        overall_record["ties"] += 1

def add_history(result):
    entry = {
        "game": result["game"],
        "score": f"User {result['user_score']} - Computer {result['computer_score']}",
        "winner": result["winner"]
    }
    history.append(entry)

def show_record():
    print("\n===== OVERALL RECORD =====")
    print("User Wins:", overall_record["user_wins"])
    print("Computer Wins:", overall_record["computer_wins"])
    print("Ties:", overall_record["ties"])

def show_history():
    print("\n1. View ALL history")
    print("2. View history for ONE game")
    choice = input("Choose an option: ")

    if choice == "1":
        print("\n===== COMPLETE HISTORY =====")
        for entry in history:
            print(f"{entry['game']} | {entry['score']} | Winner: {entry['winner']}")

