def main_menu():
    while True:
        print("\n===== MAIN GAME HUB =====")
        print("1. Play Rock Paper Scissors Shoot")
        print("2. Play Connect 4")
        print("3. Play Word Guesser")
        print("4. Game Descriptions")
        print("5. View Overall Record")
        print("6. View Game History")
        print("7. Exit")

        choice = input("Choose an option: ")

        if choice == "1":
            result = play_rps()
            update_record(result)
            add_history(result)

        elif choice == "2":
            result = play_connect4()
            update_record(result)
            add_history(result)

        elif choice == "3":
            result = play_word_guesser()
            update_record(result)
            add_history(result)

        elif choice == "4":
            print("\n===== GAME DESCRIPTIONS =====")
            print("Rock Paper Scissors Shoot: Try to beat the computer with your move.")
            print("Connect 4: Get four pieces in a row before the computer does.")
            print("Word Guesser: Try to guess the hidden word.")

        elif choice == "5":
            show_record()

        elif choice == "6":
            show_history()

        elif choice == "7":
            print("Thanks for playing!")
            break

        else:
            print("Invalid choice. Try again.")

# Start the program
main_menu()

