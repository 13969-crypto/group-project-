import random

def play_number_guess():
    print("\n umber Guessing Game")
    print("Guess the secret number between 1 and 100.")
    while True:
        secret_number = random.randint(1, 100)
        attempts = 0
        game_won = False

        while not game_won:
            user_input = input("\nEnter your guess (1-100): ").strip()

            if not user_input.isdigit():
                print("Invalid input,Please enter a number.")
                continue
            
            guess = int(user_input)
            if guess < 1 or guess > 100:
                print("Stay between 1 and 100.")
                continue
            attempts += 1

            if guess < secret_number:
                print("Too low")
            elif guess > secret_number:
                print("Too high")
            else:
                print(f"Correct,You won in {attempts} tries.")
                game_won = True

        print("\nGame Over!")
        choice = input("Type 'R' to Restart or 'M' for Main Menu: ").upper().strip()
